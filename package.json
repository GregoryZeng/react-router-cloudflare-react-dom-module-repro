{
  "name": "react-router-cloudflare-react-dom-module-repro",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "dev": "react-router dev --port 5173",
    "serve:built": "wrangler dev build/server/index.js --config build/server/wrangler.json --port 4173",
    "typecheck": "pnpm cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.10.0",
    "@tailwindcss/vite": "^4.1.13",
    "@vidstack/react": "^1.12.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@react-router/dev": "^7.13.1",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.75.0"
  },
  "packageManager": "pnpm@10.28.0"
}
